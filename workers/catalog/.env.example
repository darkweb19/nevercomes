# NeverComes catalog worker — environment variables
# Copy this to .env and fill in the values.
# Run `npx supabase status` against a local dev stack to get SUPABASE_URL
# and SUPABASE_SERVICE_ROLE_KEY for local development.

# Supabase project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# service_role key — SERVER-ONLY. NEVER prefix with NEXT_PUBLIC_. NEVER commit the real value.
# Local dev: copy from `npx supabase status` output.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — used by the catalog worker to call Claude Haiku 4.5.
ANTHROPIC_API_KEY=
