# Copy to .env.local and fill in. NEVER commit real values.

# Public — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server ONLY — never prefix with NEXT_PUBLIC_, never commit, never import client-side
SUPABASE_SERVICE_ROLE_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Offline catalog worker ONLY (workers/catalog — see its own .env.example).
# Never used by the Next.js app, never NEXT_PUBLIC_. Lives in GitHub Actions secrets in CI.
ANTHROPIC_API_KEY="<your-anthropic-api-key>"
